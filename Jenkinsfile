pipeline{
    agent any
    stages{
        stage('Build') {
            steps {
                echo 'Building...'
        }
    }
    stage('Groovy'){
        steps{
            script{
                def course = 'Jenkins Pipeline'
                if(course=='Jenkins Pipeline'){
                    println("Course is correct")
                }else
                println("Course is incorrect")
        }
    }
    }
    
    }
}
