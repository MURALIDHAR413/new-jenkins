pipeline{
    stages{
        stage('Build') {
            steps {
                echo 'Building...'
        }
    }
    stage('Groovy'){
        steps{
            script{
                def course = 'Jenkins Pipeline'
                if(course=='Jenkins Pipeline'){
                    prinln("Course is correct")
                }else
                prinln("Course is incorrect")
        }
    }
    }
    
    }
}
